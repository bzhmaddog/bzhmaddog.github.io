{
  "name": "Resume",
  "version": "1.0.1",
  "description": "",
  "main": "index.js",
  "scripts": {
    "serve": "serve .",
    "validate": "resume validate --resume resume/resume.en.json",
    "build": "resume export resume/index.html --resume resume/resume.en.json --theme ./resume/theme",
    "pdf": "node resume/export-pdf.js",
    "watch": "chokidar 'resume/theme/**' 'resume/resume.en.json' -c 'npm run build'",
    "dev": "concurrently --names 'serve,watch' -c 'blue,green' \"npm run serve\" \"npm run watch\"",
    "audit": "resume audit resume/resume.en.json --theme ./resume/theme",
    "prepare": "husky"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "chokidar-cli": "^3.0.0",
    "concurrently": "^10.0.3",
    "handlebars": "^4.7.9",
    "husky": "^9.1.7",
    "moment": "^2.30.1",
    "resume-cli": "^3.7.1",
    "serve": "^14.2.6"
  },
  "overrides": {
    "axios": "^1.8.0",
    "braces": "^3.0.3",
    "dset": "^3.1.4",
    "js-yaml": "^5.1.0",
    "markdown-it": "^14.2.0",
    "micromatch": "^4.0.8",
    "pug": "^3.0.4",
    "pug-code-gen": "^3.0.4",
    "send": "^0.19.0",
    "serve-static": "^1.16.1"
  }
}
